# ── Archery.Services environment ──
# Copy to .env (local) and set the same vars in Vercel → Project → Settings → Environment Variables.

# Supabase Postgres connection string.
# Supabase → Project Settings → Database → Connection string → URI.
# IMPORTANT for serverless: use the POOLED "Transaction" connection (host ...pooler.supabase.com, port 6543).
DATABASE_URL=postgresql://postgres.PROJECTREF:YOUR-DB-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Razorpay → Dashboard → Account & Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx
# Same key id, exposed to the browser checkout (safe — it's the publishable id)
PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Admin panel password (protects all admin write APIs)
ADMIN_PASSWORD=set-a-strong-password
